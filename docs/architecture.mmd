        Gemini["GEMINI.md"]
        Cline["Cline memory bank"]
    end

    Source --> Adopt --> Context
    Context --> Render --> Agents
    Render --> Lock
    Context --> Check
    Lock --> Check
    Context --> Gate
    Events --> Review --> Context
